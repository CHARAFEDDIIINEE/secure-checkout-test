{
  "name": "secure-checkout-wasm",
  "version": "1.0.0",
  "description": "Secure drop-in replacement for actions/checkout — compiled from Rust to WebAssembly",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:wasm":     "cargo build --target wasm32-unknown-unknown --release --lib && cp target/wasm32-unknown-unknown/release/secure_checkout_wasm.wasm .",
    "build:wasm:dev": "cargo build --target wasm32-unknown-unknown --lib && cp target/wasm32-unknown-unknown/debug/secure_checkout_wasm.wasm .",
    "build":          "npm run build:wasm",
    "validate":       "node scripts/validate-wasm.js",
    "test:unit":      "cargo test --lib",
    "test:local":     "node scripts/test-local.js",
    "test":           "npm run test:unit && npm run test:local",
    "lint":           "cargo clippy --target wasm32-unknown-unknown -- -D warnings",
    "audit":          "cargo audit && npm audit --audit-level=high",
    "clean":          "cargo clean && rm -f secure_checkout_wasm.wasm"
  },
  "dependencies": {
    "@actions/core": "^1.10.1"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "index.js",
    "action.yml",
    "secure_checkout_wasm.wasm",
    "README.md"
  ]
}